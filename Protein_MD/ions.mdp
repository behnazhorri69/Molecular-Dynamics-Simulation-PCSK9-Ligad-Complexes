; ions.mdp - ion placement (short EM)
integrator  = steep
emtol       = 100.0
emstep      = 0.01
nsteps      = 5000

nstenergy   = 10
nstlog      = 10

cutoff-scheme = Verlet
nstlist     = 10
coulombtype = PME
rcoulomb    = 1.0
rvdw        = 1.0
pme_order   = 4
fourierspacing = 0.12

pbc         = xyz







